    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
        import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

        // 全局状态
        let ws = null;
        let models = [];
        let reconnectAttempts = 0;
        let reconnectTimer = null;
        let heartbeatTimer = null;
        let scene, camera, renderer, controls, currentModel;
        let autoRotate = false;
        const MAX_RECONNECT_ATTEMPTS = 5;
        const RECONNECT_DELAY = 3000;

        // 初始化 WebSocket
        function initWebSocket() {
            if (ws?.readyState === WebSocket.OPEN) return;

            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/ws`;

            try {
                ws = new WebSocket(wsUrl);

                ws.onopen = () => {
                    console.log('✅ WebSocket 已连接');
                    updateConnectionStatus('connected');
                    reconnectAttempts = 0;
                    startHeartbeat();
                };

                ws.onmessage = (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        handleWebSocketMessage(msg);
                    } catch (e) {
                        console.error('消息解析错误:', e);
                    }
                };

                ws.onclose = (e) => {
                    console.log('❌ WebSocket 断开', e.code, e.reason);
                    updateConnectionStatus('disconnected');
                    stopHeartbeat();
                    attemptReconnect();
                };

                ws.onerror = (error) => {
                    console.error('WebSocket 错误:', error);
                    updateConnectionStatus('error');
                };

            } catch (error) {
                console.error('WebSocket 初始化失败:', error);
                attemptReconnect();
            }
        }

        function startHeartbeat() {
            stopHeartbeat();
            heartbeatTimer = setInterval(() => {
                if (ws?.readyState === WebSocket.OPEN) {
                    ws.send(JSON.stringify({ action: 'ping' }));
                }
            }, 30000);
        }

        function stopHeartbeat() {
            if (heartbeatTimer) {
                clearInterval(heartbeatTimer);
                heartbeatTimer = null;
            }
        }

        function attemptReconnect() {
            if (reconnectAttempts >= MAX_RECONNECT_ATTEMPTS) {
                showToast('连接失败，请刷新页面重试', 'error');
                return;
            }

            reconnectAttempts++;
            updateConnectionStatus('reconnecting', reconnectAttempts);

            if (reconnectTimer) clearTimeout(reconnectTimer);
            reconnectTimer = setTimeout(() => {
                console.log(`🔄 尝试重连 (${reconnectAttempts}/${MAX_RECONNECT_ATTEMPTS})...`);
                initWebSocket();
            }, RECONNECT_DELAY);
        }

        function updateConnectionStatus(status, attempt = null) {
            const el = document.getElementById('connection-status');
            const statusMap = {
                'connected': { text: '实时连接中', class: 'text-green-400', dot: 'bg-green-400' },
                'disconnected': { text: '已断开', class: 'text-red-400', dot: 'bg-red-400' },
                'error': { text: '连接错误', class: 'text-red-400', dot: 'bg-red-400' },
                'reconnecting': { text: `重连中 ${attempt}/${MAX_RECONNECT_ATTEMPTS}`, class: 'text-yellow-400', dot: 'bg-yellow-400 animate-pulse' }
            };

            const s = statusMap[status];
            el.className = `px-3 py-1.5 glass rounded-full text-xs font-medium ${s.class} flex items-center gap-1.5`;
            el.innerHTML = `<span class="w-1.5 h-1.5 rounded-full ${s.dot}"></span>${s.text}`;
        }

        function handleWebSocketMessage(msg) {
            switch(msg.type) {
                case 'init':
                    models = msg.models || [];
                    updateOnlineCount(msg.online_count);
                    renderGallery();
                    break;

                case 'new_model':
                    models.unshift(msg.data);
                    renderGallery();
                    showToast(`🎉 新任务: ${msg.data.prompt.substring(0, 30)}...`, 'success');
                    break;

                case 'status_update':
                    updateModelCard(msg.data);
                    if (msg.data.status === 'success' && msg.data.progress === 100) {
                        showToast('✅ 模型生成完成！', 'success');
                    } else if (msg.data.status === 'failed') {
                        showToast(`❌ 生成失败: ${msg.data.error_message || '未知错误'}`, 'error');
                    }
                    break;

                case 'online_update':
                    updateOnlineCount(msg.count);
                    break;

                case 'delete_model':
                    models = models.filter(m => m.id !== msg.model_id);
                    renderGallery();
                    break;

                case 'ping':
                    ws.send(JSON.stringify({ action: 'pong' }));
                    break;
            }
        }

        function updateOnlineCount(count) {
            document.getElementById('online-count').textContent = count || 1;
        }

        // 生成模型
        async function generateModel() {
            const input = document.getElementById('prompt-input');
            const prompt = input.value.trim();

            if (!prompt) {
                showToast('请输入描述文本', 'warning');
                input.focus();
                return;
            }

            const btn = document.getElementById('generate-btn');
            const originalContent = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = `<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> 提交中...`;

            try {
                const response = await fetch('/api/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        prompt: prompt,
                        negative_prompt: 'low quality, blurry, watermark, text'
                    })
                });

                const result = await response.json();

                if (result.success) {
                    input.value = '';
                    document.getElementById('char-count').textContent = '0/1024';
                    showToast('✅ 任务已提交，正在生成...', 'info');
                } else {
                    throw new Error(result.message || '提交失败');
                }

            } catch (error) {
                console.error('Error:', error);
                showToast('提交失败: ' + error.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        }
        window.generateModel = generateModel;

        function setPrompt(text) {
            const input = document.getElementById('prompt-input');
            input.value = text;
            input.focus();
            updateCharCount();
        }
        window.setPrompt = setPrompt;

        function updateCharCount() {
            const input = document.getElementById('prompt-input');
            const count = input.value.length;
            document.getElementById('char-count').textContent = `${count}/1024`;
        }

        document.getElementById('prompt-input')?.addEventListener('input', updateCharCount);

        // 渲染画廊
        function renderGallery() {
            const grid = document.getElementById('gallery-grid');
            const emptyState = document.getElementById('empty-state');
            const totalCount = document.getElementById('total-count');

            totalCount.textContent = `${models.length} 个模型`;

            if (models.length === 0) {
                grid.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            grid.innerHTML = models.map((model, index) => createModelCard(model, index)).join('');
        }

        function createModelCard(model, index) {
            const statusConfig = {
                'pending': { color: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30', icon: '⏳', text: '等待中' },
                'queued': { color: 'bg-blue-500/20 text-blue-400 border-blue-500/30', icon: '📋', text: '排队中' },
                'running': { color: 'bg-purple-500/20 text-purple-400 border-purple-500/30', icon: '⚡', text: `生成中 ${Math.round(model.progress)}%` },
                'success': { color: 'bg-green-500/20 text-green-400 border-green-500/30', icon: '✨', text: '已完成' },
                'failed': { color: 'bg-red-500/20 text-red-400 border-red-500/30', icon: '❌', text: '失败' },
                'banned': { color: 'bg-red-500/20 text-red-400 border-red-500/30', icon: '🚫', text: '已封禁' },
                'expired': { color: 'bg-gray-500/20 text-gray-400 border-gray-500/30', icon: '⌛', text: '已过期' }
            };

            const status = statusConfig[model.status] || statusConfig['pending'];
            const isCompleted = model.status === 'success';
            const isProcessing = model.status === 'running' || model.status === 'queued';

            // 缩略图处理
            let thumbnailHtml = '';
            if (model.thumbnail_url) {
                thumbnailHtml = `<img src="${model.thumbnail_url}" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" loading="lazy" alt="">`;
            } else {
                thumbnailHtml = `<div class="text-5xl transform group-hover:scale-110 transition-transform duration-300">${status.icon}</div>`;
            }

            return `
                <div class="model-card glass rounded-2xl overflow-hidden fade-in relative group" 
                     id="card-${model.id}"
                     style="animation-delay: ${index * 50}ms">

                    <!-- 缩略图区域 -->
                    <div class="h-56 bg-gradient-to-br from-purple-900/20 to-pink-900/20 flex items-center justify-center relative overflow-hidden cursor-pointer ${isCompleted ? 'hover:opacity-90' : ''}"
                         onclick="${isCompleted ? `viewModel('${model.id}')` : ''}">

                        ${thumbnailHtml}

                        <!-- 状态标签 -->
                        <div class="absolute top-3 right-3 px-3 py-1.5 rounded-full text-xs font-bold border backdrop-blur-md ${status.color} shadow-lg">
                            ${status.text}
                        </div>

                        <!-- 进度条 -->
                        ${isProcessing ? `
                            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-gray-800">
                                <div class="h-full bg-gradient-to-r from-purple-500 to-pink-500 progress-shine relative" 
                                     style="width: ${model.progress}%">
                                    <div class="absolute right-0 top-0 bottom-0 w-2 bg-white/50 blur-sm"></div>
                                </div>
                            </div>
                        ` : ''}

                        <!-- 悬停提示 -->
                        ${isCompleted ? `
                            <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center backdrop-blur-sm">
                                <div class="text-center transform translate-y-4 group-hover:translate-y-0 transition-transform">
                                    <div class="w-16 h-16 rounded-full bg-white/20 flex items-center justify-center mx-auto mb-2">
                                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </div>
                                    <span class="text-sm font-bold">点击查看 3D</span>
                                </div>
                            </div>
                        ` : ''}
                    </div>

                    <!-- 信息区域 -->
                    <div class="p-4 space-y-3">
                        <div>
                            <h4 class="font-bold text-sm line-clamp-2 leading-relaxed mb-1" title="${model.prompt}">${model.prompt}</h4>
                            <div class="flex justify-between items-center text-xs text-gray-500">
                                <span class="flex items-center gap-1">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                    ${model.author}
                                </span>
                                <span>${model.created_at}</span>
                            </div>
                        </div>

                        ${model.file_size ? `
                            <div class="text-xs text-gray-600 font-mono flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
                                ${(model.file_size / 1024).toFixed(1)} KB
                            </div>
                        ` : ''}

                        ${model.error_message ? `
                            <div class="text-xs text-red-400 bg-red-500/10 p-2 rounded border border-red-500/20 line-clamp-2" title="${model.error_message}">
                                错误: ${model.error_message}
                            </div>
                        ` : ''}

                        ${isCompleted ? `
                            <div class="flex gap-2 pt-2 border-t border-white/5">
                                <button onclick="event.stopPropagation(); viewModel('${model.id}')" class="flex-1 py-2 bg-white/5 hover:bg-white/10 rounded-lg text-xs font-medium transition">
                                    查看 3D
                                </button>
                                <a href="${model.model_url}" download class="flex-1 py-2 bg-purple-600/20 hover:bg-purple-600/30 text-purple-400 rounded-lg text-xs font-medium transition text-center">
                                    下载
                                </a>
                            </div>
                        ` : ''}
                    </div>
                </div>
            `;
        }

        function updateModelCard(model) {
            const card = document.getElementById(`card-${model.id}`);
            if (card) {
                const index = models.findIndex(m => m.id === model.id);
                if (index !== -1) {
                    models[index] = model;
                    card.outerHTML = createModelCard(model, index);
                }
            } else if (!models.find(m => m.id === model.id)) {
                models.unshift(model);
                renderGallery();
            }
        }

        // 3D 查看器
        function viewModel(modelId) {
            const model = models.find(m => m.id === modelId);
            if (!model || model.status !== 'success') return;

            document.getElementById('viewer-title').textContent = model.prompt;
            document.getElementById('viewer-meta').textContent = `${model.created_at} • ${(model.file_size / 1024).toFixed(1)} KB`;
            document.getElementById('viewer-modal').classList.remove('hidden');

            // 确保下载链接正确
            const downloadLink = document.getElementById('download-link');
            let modelUrl = model.model_url;
            if (!modelUrl.startsWith('http')) {
                modelUrl = window.location.origin + modelUrl;
            }
            downloadLink.href = modelUrl;

            initThreeJS();
            loadModel(modelUrl);
        }
        window.viewModel = viewModel;

        function initThreeJS() {
            const container = document.getElementById('viewer-container');
            container.innerHTML = '';

            // 场景设置
            scene = new THREE.Scene();

            // 相机
            camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
            camera.position.set(5, 3, 5);

            // 渲染器
            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.toneMapping = THREE.ACESFilmicToneMapping;
            renderer.toneMappingExposure = 1;
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            container.appendChild(renderer.domElement);

            // 环境
            const pmremGenerator = new THREE.PMREMGenerator(renderer);
            scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;

            // 灯光
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
            scene.add(ambientLight);

            const dirLight = new THREE.DirectionalLight(0xffffff, 1);
            dirLight.position.set(5, 10, 7);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.width = 2048;
            dirLight.shadow.mapSize.height = 2048;
            scene.add(dirLight);

            const fillLight = new THREE.DirectionalLight(0x8888ff, 0.3);
            fillLight.position.set(-5, 0, -5);
            scene.add(fillLight);

            // 控制器
            controls = new OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.minDistance = 1;
            controls.maxDistance = 50;
            controls.target.set(0, 0, 0);

            // 网格
            const gridHelper = new THREE.GridHelper(10, 10, 0x444444, 0x222222);
            gridHelper.position.y = -1;
            scene.add(gridHelper);

            animate();
        }

        function loadModel(url) {
            const container = document.getElementById('viewer-container');

            // 加载指示器
            const loader = document.createElement('div');
            loader.className = 'absolute inset-0 flex items-center justify-center bg-black/50 backdrop-blur-sm z-10';
            loader.innerHTML = `
                <div class="text-center">
                    <div class="w-16 h-16 border-4 border-purple-500/30 border-t-purple-500 rounded-full animate-spin mx-auto mb-4"></div>
                    <p class="text-gray-300">加载模型中...</p>
                    <p class="text-xs text-gray-500 mt-1" id="load-progress">0%</p>
                </div>
            `;
            container.appendChild(loader);

            // 清理旧模型
            if (currentModel) {
                scene.remove(currentModel);
                currentModel.traverse((child) => {
                    if (child.isMesh) {
                        child.geometry?.dispose();
                        if (child.material) {
                            if (Array.isArray(child.material)) {
                                child.material.forEach(m => m.dispose());
                            } else {
                                child.material.dispose();
                            }
                        }
                    }
                });
                currentModel = null;
            }

            const gltfLoader = new GLTFLoader();
            gltfLoader.load(
                url,
                (gltf) => {
                    loader.remove();

                    currentModel = gltf.scene;

                    // 计算包围盒
                    const box = new THREE.Box3().setFromObject(currentModel);
                    const center = box.getCenter(new THREE.Vector3());
                    const size = box.getSize(new THREE.Vector3());

                    // 居中并缩放
                    currentModel.position.x = -center.x;
                    currentModel.position.y = -center.y + size.y / 2;
                    currentModel.position.z = -center.z;

                    const maxDim = Math.max(size.x, size.y, size.z);
                    const scale = 3 / maxDim;
                    currentModel.scale.setScalar(scale);

                    // 设置相机
                    const distance = maxDim * 2;
                    camera.position.set(distance, distance * 0.5, distance);
                    camera.lookAt(0, 0, 0);
                    controls.target.set(0, 0, 0);
                    controls.update();

                    // 阴影
                    currentModel.traverse((child) => {
                        if (child.isMesh) {
                            child.castShadow = true;
                            child.receiveShadow = true;
                        }
                    });

                    scene.add(currentModel);
                    console.log('✅ 模型加载成功');
                },
                (progress) => {
                    if (progress.lengthComputable) {
                        const percent = Math.round((progress.loaded / progress.total) * 100);
                        const progressEl = document.getElementById('load-progress');
                        if (progressEl) progressEl.textContent = `${percent}%`;
                    }
                },
                (error) => {
                    console.error('模型加载失败:', error);
                    loader.innerHTML = `
                        <div class="text-center text-red-400">
                            <svg class="w-16 h-16 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <p>模型加载失败</p>
                            <p class="text-xs text-gray-500 mt-2">${error.message}</p>
                        </div>
                    `;
                    setTimeout(() => loader.remove(), 3000);
                }
            );
        }

        function animate() {
            requestAnimationFrame(animate);

            controls.update();

            if (currentModel && autoRotate) {
                currentModel.rotation.y += 0.005;
            }

            renderer.render(scene, camera);
        }

        function closeViewer() {
            document.getElementById('viewer-modal').classList.add('hidden');
            if (renderer) {
                renderer.dispose();
                renderer = null;
            }
            currentModel = null;
            scene = null;
            camera = null;
            controls = null;
        }
        window.closeViewer = closeViewer;

        function resetCamera() {
            if (!currentModel || !camera) return;
            const box = new THREE.Box3().setFromObject(currentModel);
            const size = box.getSize(new THREE.Vector3());
            const maxDim = Math.max(size.x, size.y, size.z);
            const distance = maxDim * 2;
            camera.position.set(distance, distance * 0.5, distance);
            camera.lookAt(0, 0, 0);
            controls.target.set(0, 0, 0);
            controls.update();
        }
        window.resetCamera = resetCamera;

        function toggleAutoRotate() {
            autoRotate = !autoRotate;
            const btn = document.getElementById('rotate-btn');
            btn.classList.toggle('bg-purple-600');
            btn.classList.toggle('text-white');
        }
        window.toggleAutoRotate = toggleAutoRotate;

        // 工具函数
        function clearCompleted() {
            if (!confirm('确定清空所有已完成的模型？')) return;
            models = models.filter(m => m.status !== 'success');
            renderGallery();
            showToast('已清空完成项', 'info');
        }
        window.clearCompleted = clearCompleted;

        async function refreshGallery() {
            try {
                const response = await fetch('/api/gallery');
                const data = await response.json();
                models = data.models;
                renderGallery();
                showToast('🔄 画廊已刷新', 'success');
            } catch (error) {
                showToast('刷新失败', 'error');
            }
        }
        window.refreshGallery = refreshGallery;

        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');

            const colors = {
                success: 'border-green-500/50 bg-green-500/10 text-green-400',
                error: 'border-red-500/50 bg-red-500/10 text-red-400',
                warning: 'border-yellow-500/50 bg-yellow-500/10 text-yellow-400',
                info: 'border-blue-500/50 bg-blue-500/10 text-blue-400'
            };

            toast.className = `toast glass px-4 py-3 rounded-xl border ${colors[type]} flex items-center gap-2 min-w-[200px]`;
            toast.innerHTML = `
                <span class="text-lg">${type === 'success' ? '✅' : type === 'error' ? '❌' : type === 'warning' ? '⚠️' : 'ℹ️'}</span>
                <span class="text-sm font-medium">${message}</span>
            `;

            container.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // 事件监听
        window.addEventListener('resize', () => {
            if (camera && renderer) {
                const container = document.getElementById('viewer-container');
                camera.aspect = container.clientWidth / container.clientHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(container.clientWidth, container.clientHeight);
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeViewer();
        });

        // 初始化
        window.addEventListener('load', () => {
            initWebSocket();
        });

        // 页面可见性变化时重连
        document.addEventListener('visibilitychange', () => {
            if (!document.hidden && (!ws || ws.readyState !== WebSocket.OPEN)) {
                initWebSocket();
            }
        });
    </script>
</body>
</html>
"""

if __name__ == "__main__":
    import uvicorn

    uvicorn.run(
        app,
        host="0.0.0.0",
        port=8000,
        log_level="info",
        access_log=True
